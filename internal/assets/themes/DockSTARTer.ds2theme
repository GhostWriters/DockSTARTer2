[metadata]
name = "DockSTARTer"
description = "The default DockSTARTer2 theme"
author = "CLHatch"

[syntax]
semantic_prefix = "{{|"
semantic_suffix = "|}}"
direct_prefix   = "{{["
direct_suffix   = "]}}"

[palette]
primary = "black"
secondary = "white"
screen_fg = "$primary"
screen_bg = "$secondary"
accent = "cyan"

[styles]
# Backdrop
Screen = "{{[$primary:$secondary:-]}}"
StatusBar = "{{[black:$accent:-]}}"
StatusBarBorder = "{{|StatusBar|}}"

# Dialogs and panels
Dialog = "{{[black:$accent:-]}}"
Border = "{{[white:-:-]}}"
Border2 = "{{[black:-:-]}}"
Shadow = "{{|Screen:::D|}}"
ProgramBox = "{{[white:black:-]}}"
ConsoleBorder = "{{|Helpline|}}"

# Header bar
StatusFields = "{{[blue:white:-BR]}}"
StatusName = "{{|StatusFields|}}"
StatusVersion = "{{|StatusFields|}}"
StatusVersionBrackets = "{{|StatusFields|}}"
StatusVersionSpace = "{{[-]}}"
StatusVersionFocused = "{{[black:red:-]}}"
StatusFlags = "{{|Dialog|}}"
StatusFlagsBrackets = "{{[$accent:black:-B]}}"
StatusFlagsSpace = "{{|StatusVersionSpace|}}"
StatusUpdate = "{{[-:-:-R]}}"
StatusUpdateBrackets = "{{|StatusVersionBrackets|}}"
StatusUpdateMarker = "{{|StatusUpdate|}}"
StatusHostname = "{{|StatusFields|}}"
StatusBarFocused = "{{|TagFocused|}}"

# Titles
Title = "{{[black:-:-U]}}"
TitleHelp = "{{|Title|}}"
TitleNotice = "{{[white:green:B]}}"
TitleWarn = "{{|Title::yellow|}}"
TitleError = "{{|Title::red|}}"
TitleSuccess = "{{|Title::green|}}"
TitleWarning = "{{|Title::yellow|}}"
TitleQuestion = "{{|Title::yellow|}}"
ConsoleTitle = "{{|ConsoleBorder|}}"
ConsoleTitleChangedIndicator = "{{|TitleNotice|}}"
TitleCheckbox = ""
TitleCheckboxFocused = "{{[:green]}}"
TitleSubMenu = "{{|Title|}}"
TitleSubMenuFocused = "{{|Title:::R|}}"
TitleFocusIndicator = "{{[red::-B]}}"
TitleUnfocusedIndicator = ""

# Large Titles
LargeTitleArea = "{{[white:black:-]}}"
LargeTitleAreaHelp = "{{[black:yellow:-]}}"
LargeTitleAreaNotice = "{{[black:green:-]}}"
LargeTitleAreaWarn = "{{[black:yellow:-]}}"
LargeTitleAreaWarning = "{{[black:yellow:-]}}"
LargeTitleAreaError = "{{[black:red:-]}}"
LargeTitleAreaSuccess = "{{[black:green:-]}}"
LargeTitleAreaQuestion = "{{[black:yellow:-]}}"
LargeTitle = "{{[:::U]}}"
LargeTitleHelp = "{{|LargeTitle|}}"
LargeTitleNotice = "{{|TitleNotice|}}"
LargeTitleWarn = "{{|TitleWarn|}}"
LargeTitleWarning = "{{|TitleWarning|}}"
LargeTitleError = "{{|TitleError|}}"
LargeTitleSuccess = "{{|TitleSuccess|}}"
LargeTitleQuestion = "{{|TitleQuestion|}}"
LargeTitleFocusIndicator = "{{|TitleFocusIndicator|}}"
LargeTitleUnfocusedIndicator = "{{|TitleUnfocusedIndicator|}}"
LargeTitleSubMenu = "{{|TitleSubMenu|}}"
LargeTitleSubMenuFocused = "{{|TitleSubMenuFocused|}}"
LargeIconFocused = "{{[red::B]}}"
LargeIconPressed = "{{[white:red:B]}}"
LargeHelpIconInactive = ""
LargeRefreshIconInactive = ""
LargeExitIconInactive = "{{[::R]}}"

# Subtitles
Subtitle = "{{[black:white:-]}}"
CommandLine = "{{[white:blue:-]}}"

# Headings
Heading = "{{[-]}}{{[::R]}}"
HeadingTag = "{{[-]}}{{[white::R]}}"
HeadingValue = "{{[-]}}{{[::BR]}}"
HeadingAppDescription = "{{[-]}}{{[::B]}}"

# Menus
TagBrackets = "{{|Dialog|}}"
TagSpinner = ""
TagKey = "{{|Tag:red|}}"
Tag = "{{[black:-:-b]}}"
Item = "{{[black:-]}}"
TagKeyFocused = "{{|TagFocused:::-B|}}"
TagFocused = "{{|Tag::red|}}"
ItemFocused = "{{[black:red:-]}}"
ListItem = "{{[cyan:black]}}"
ListItemFocused = "{{|ItemFocused|}}"
ListItemUserDefined = "{{[blue:white]}}"
ListItemUserDefinedFocused = "{{|ItemFocused|}}"
ListItemDeprecated = "{{|ListItem:red|}}"
ListItemDeprecatedFocused = "{{|ListItemFocused|}}"
OptionValue = "{{[white:blue:-]}}"
OptionValueFocused = "{{|OptionValue:::-B|}}"

# Help
Helpline = "{{|Dialog|}}"
HelpTag = "{{[black:red]}}"
HelpItem = "{{[black]}}"

# Checkboxes
CheckboxOff = "{{|Dialog|}}"
CheckboxOn = "{{|TagKey|}}"
CheckboxBracketsOff = "{{|Dialog|}}"
CheckboxBracketsOn = "{{|Dialog|}}"
CheckboxOnFocused = "{{|TagFocused|}}"
CheckboxOffFocused = "{{|TagFocused|}}"
CheckboxBracketsOnFocused = "{{|TagFocused|}}"
CheckboxBracketsOffFocused = "{{|TagFocused|}}"

# Radio buttons
RadioOff = "{{|Dialog|}}"
RadioOn = "{{|TagKey|}}"
RadioBracketsOff = "{{|Dialog|}}"
RadioBracketsOn = "{{|Dialog|}}"
RadioOnFocused = "{{|TagFocused|}}"
RadioOffFocused = "{{|TagFocused|}}"
RadioBracketsOnFocused = "{{|TagFocused|}}"
RadioBracketsOffFocused = "{{|TagFocused|}}"

# Buttons
ButtonActive = "{{[white:red:-B]}}"
ButtonInactive = "{{[$primary:$secondary:-]}}"
ButtonSpinner = ""
ButtonSpinnerLarge = ""
ButtonKeyActive = "{{|ButtonActive|}}"
ButtonKeyInactive = "{{|ButtonInactive:red|}}"

# Icons
IconFocused = "{{|ButtonActive|}}"
IconPressed = "{{[red:white:-B]}}"
IconInactive = ""
HelpIconInactive = "{{|IconInactive|}}"
RefreshIconInactive = "{{|IconInactive|}}"
ExitIconInactive = "{{[::R]}}"
ResizeUpIconInactive = "{{|ConsoleBorder|}}"
ResizeDnIconInactive = "{{|ConsoleBorder|}}"

# Env editor variable types
EnvBuiltin = "{{|Dialog:::B|}}"
EnvInvalid = "{{|TitleError|}}"
EnvDuplicate = "{{|TitleWarn|}}"
EnvPendingDelete = "{{|Dialog:::DS|}}"
EnvReadOnly = "{{|Dialog:::D|}}"

# Env editor
LineComment = "{{|Dialog:::-RB|}}"
ModifiedText = "{{|Dialog:::-R|}}"

# Env editor line numbers
LineNumber = "{{|Dialog:::-D|}}"
LineNumberFocused = "{{|Dialog:red::-B|}}"
LineNumberModified = "{{|ModifiedText|}}"
LineNumberModifiedFocused = "{{[red:black:B]}}"
LineNumberBrackets = "{{|Dialog|}}"

# Markers and cursor
Marker = ""
MarkerAdded = "{{|Marker::green|}}"
MarkerDeleted = "{{|Marker::red|}}"
MarkerModified = "{{|Marker::yellow|}}"
MarkerInvalid = "{{[white:red:B]}}"
MarkerLocked = "{{|MarkerInvalid|}}"
MarkerLockedLarge = "{{|MarkerLocked|}}"
TextCursor = "{{[:white:]}}"

# Scrollbar
Scrollbar = "{{|Border2|}}"
ScrollbarThumb = "{{|Border|}}"
ScrollbarArrows = "{{|Border|}}"

# Keys, progress, and indicators
KeyCap = "{{[::-R]}}"
ProgressWaiting = "{{[$primary:$secondary:-B]}}"
ProgressInProgress = "{{[white:$accent:-B]}}"
ProgressCompleted = "{{[$accent:black:-B]}}"

# Inline text highlights
Highlight = "{{[-]}}{{[yellow::B]}}"
ApplicationName = "{{|Highlight|}}"
RunningCommand = "{{|Highlight|}}"
FailingCommand = "{{|TitleError|}}"
UserCommand = "{{|Highlight|}}"
Branch = "{{|Highlight|}}"
Version = "{{|Highlight|}}"
MenuPage = "{{|Highlight|}}"
File = "{{|Highlight|}}"
Folder = "{{|Highlight|}}"
App = "{{|Highlight|}}"
IPAddress = "{{|Highlight|}}"
URL = "{{[magenta::U]}}"
Var = "{{|Highlight|}}"
User = "{{|Highlight|}}"
Theme = "{{|Highlight|}}"
Yes = "{{|TitleSuccess|}}"
No = "{{|TitleError|}}"

[defaults]
dialog_title_align = "center"
submenu_title_align = "left"
panel_title_align = "center"
menu_brackets = false
line_number_brackets = true
